MONGODB_URI=mongodb://127.0.0.1:27017/HDSweeper
PORT=4900
HOST=127.0.0.1
ENCRYPTION_KEY=change-this-to-a-random-64-char-hex-string-for-mnemonic-encryption
MNEMONIC=word1 word2 word3 ...
CUSTODIAL_WALLET=0xYourCustodialAddressHere
ENABLE_CRON=true
START_SWEEP_ON_RUN=false

# RPC Endpoints (leave empty to skip chain)
RPC_ETH=https://your-ethereum-rpc-url
RPC_BSC=https://your-bsc-rpc-url
RPC_ARBITRUM=https://your-arbitrum-rpc-url
RPC_BASE=https://your-base-rpc-url
RPC_ASSETCHAIN=https://your-assetchain-rpc-url
